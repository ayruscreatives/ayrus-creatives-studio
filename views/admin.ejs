<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Ayrus Creatives</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] } } }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { background: #0F0F0F; color: #F5F3EE; font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-screen flex flex-col">

  <% if (!loggedIn) { %>
  <!-- ── Login Page ── -->
  <div class="flex-1 flex items-center justify-center px-6">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <p class="text-xs tracking-widest uppercase text-white/30 mb-2">Ayrus Creatives</p>
        <h1 class="text-2xl font-semibold">Admin Access</h1>
        <p class="text-sm text-white/30 mt-1">Enter your password to continue</p>
      </div>
      <% if (message) { %>
      <div class="bg-red-900/30 border border-red-500/30 text-red-300 text-sm px-4 py-3 rounded-sm mb-5">
        <%= message %>
      </div>
      <% } %>
      <form action="/admin/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs text-white/40 mb-1.5">Password</label>
          <input type="password" name="password" autofocus required
            class="w-full bg-[#161616] border border-white/10 rounded-sm px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30" />
        </div>
        <button type="submit"
          class="w-full bg-[#C8A97A] text-black py-3 rounded-sm text-sm font-medium hover:bg-[#b8956a] transition-colors">
          Sign In
        </button>
      </form>
      <p class="text-center mt-6"><a href="/" class="text-xs text-white/20 hover:text-white/50 transition-colors">← Back to site</a></p>
    </div>
  </div>

  <% } else { %>
  <!-- ── Admin Panel ── -->
  <div class="max-w-3xl mx-auto px-6 py-12 w-full">

    <div class="flex items-center justify-between mb-10">
      <div>
        <p class="text-xs tracking-widest uppercase text-white/30 mb-1">Admin Panel</p>
        <h1 class="text-2xl font-semibold">Work Upload Admin</h1>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-xs text-white/30 hover:text-white transition-colors">← View Site</a>
        <form action="/admin/logout" method="POST">
          <button type="submit" class="text-xs text-white/30 hover:text-red-400 transition-colors">Logout</button>
        </form>
      </div>
    </div>

    <% if (message) { %>
    <div class="bg-green-900/30 border border-green-500/30 text-green-300 text-sm px-4 py-3 rounded-sm mb-8">
      <%= message %>
    </div>
    <% } %>

    <!-- Upload Form -->
    <div class="bg-[#161616] rounded-sm p-7 mb-10">
      <h2 class="text-sm font-medium uppercase tracking-widest text-white/40 mb-6">Add New Work</h2>
      <div id="upload-message" class="hidden mb-4 px-4 py-3 rounded-sm text-sm"></div>
      <div class="space-y-5">
        <div>
          <label class="block text-xs text-white/40 mb-1.5">Brand Name</label>
          <input type="text" id="brand" placeholder="e.g. Maaté Skincare"
            class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2.5 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30" />
        </div>
        <div>
          <label class="block text-xs text-white/40 mb-1.5">Output Type</label>
          <select id="type"
            class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2.5 text-sm text-white focus:outline-none focus:border-white/30">
            <option value="">Select type…</option>
            <option value="UGC">UGC</option>
            <option value="Brand Identity">Brand Identity</option>
            <option value="Hyper Motion">Hyper Motion</option>
            <option value="Cinematic Stills">Cinematic Stills</option>
            <option value="ASMR">ASMR</option>
            <option value="Unboxing">Unboxing</option>
            <option value="Billboard">Billboard</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-white/40 mb-1.5">One-line Brief</label>
          <input type="text" id="brief" maxlength="140" placeholder="e.g. Hero product stills for Diwali launch campaign"
            class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2.5 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30" />
        </div>
        <div>
          <label class="block text-xs text-white/40 mb-1.5">Homepage Position <span class="text-white/20">(optional)</span></label>
          <select id="position"
            class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2.5 text-sm text-white focus:outline-none focus:border-white/30">
            <option value="">— None —</option>
            <option value="featured">Featured (large left)</option>
            <option value="side-1">Side 1 (top-middle, row 1)</option>
            <option value="side-2">Side 2 (top-middle, row 2)</option>
            <option value="side-3">Side 3 (top-right, row 1)</option>
            <option value="side-4">Side 4 (top-right, row 2)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-white/40 mb-1.5">Asset (image or video)</label>
          <input type="file" id="asset" accept="image/*,video/*"
            class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2.5 text-sm text-white/60 file:mr-4 file:py-1 file:px-3 file:rounded-sm file:border-0 file:text-xs file:bg-white/10 file:text-white hover:file:bg-white/20 focus:outline-none" />
        </div>
        <div>
          <button onclick="handleUpload()"
            class="bg-[#C8A97A] text-black px-6 py-2.5 rounded-sm text-sm font-medium hover:bg-[#b8956a] transition-colors">
            Upload Work
          </button>
          <span id="upload-progress" class="ml-3 text-xs text-white/40 hidden">Uploading…</span>
        </div>
      </div>
    </div>

    <!-- Existing Work -->
    <div>
      <h2 class="text-sm font-medium uppercase tracking-widest text-white/40 mb-5">Existing Work (<%= work.length %>)</h2>
      <% if (work.length === 0) { %>
        <p class="text-white/20 text-sm">No work uploaded yet.</p>
      <% } else { %>
      <div class="space-y-3">
        <% work.forEach(function(item) { %>
        <div class="bg-[#161616] rounded-sm p-4">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-[#1C1C1C] rounded-sm overflow-hidden flex-shrink-0">
              <% if (item.file && item.isVideo) { %>
                <video src="<%= item.file %>" class="w-full h-full object-cover" muted></video>
              <% } else if (item.file) { %>
                <img src="<%= item.file %>" alt="<%= item.brand %>" class="w-full h-full object-cover" />
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-sm"><%= item.brand || '(no brand)' %></p>
              <p class="text-white/30 text-xs mt-0.5"><%= item.type || '(no type)' %> &bull; <%= item.brief || '(no brief)' %></p>
            </div>
            <div class="flex gap-2">
              <button data-edit-id="<%= item.public_id.replace(/\//g, '_') %>" onclick="toggleEdit(this.dataset.editId)"
                class="text-xs text-white/40 hover:text-white transition-colors px-2 py-1">Edit</button>
              <form action="/admin/delete/<%= item.public_id %>" method="POST" onsubmit="return confirm('Delete this item?')">
                <button type="submit" class="text-xs text-red-400/60 hover:text-red-400 transition-colors px-2 py-1">Delete</button>
              </form>
            </div>
          </div>
          <!-- Edit Form (hidden by default) -->
          <div id="edit-<%= item.public_id.replace(/\//g, '_') %>" class="hidden mt-4 pt-4 border-t border-white/10">
            <form action="/admin/update" method="POST" class="space-y-3">
              <input type="hidden" name="public_id" value="<%= item.public_id %>" />
              <input type="hidden" name="isVideo" value="<%= item.isVideo %>" />
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-white/40 mb-1">Brand Name</label>
                  <input type="text" name="brand" value="<%= item.brand %>" required
                    class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2 text-sm text-white focus:outline-none focus:border-white/30" />
                </div>
                <div>
                  <label class="block text-xs text-white/40 mb-1">Output Type</label>
                  <select name="type" required
                    class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2 text-sm text-white focus:outline-none focus:border-white/30">
                    <option value="UGC" <%= item.type==='UGC'?'selected':'' %>>UGC</option>
                    <option value="Brand Identity" <%= item.type==='Brand Identity'?'selected':'' %>>Brand Identity</option>
                    <option value="Hyper Motion" <%= item.type==='Hyper Motion'?'selected':'' %>>Hyper Motion</option>
                    <option value="Cinematic Stills" <%= item.type==='Cinematic Stills'?'selected':'' %>>Cinematic Stills</option>
                    <option value="ASMR" <%= item.type==='ASMR'?'selected':'' %>>ASMR</option>
                    <option value="Unboxing" <%= item.type==='Unboxing'?'selected':'' %>>Unboxing</option>
                    <option value="Billboard" <%= item.type==='Billboard'?'selected':'' %>>Billboard</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-xs text-white/40 mb-1">One-line Brief</label>
                <input type="text" name="brief" value="<%= item.brief %>" required maxlength="140"
                  class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2 text-sm text-white focus:outline-none focus:border-white/30" />
              </div>
              <div>
                <label class="block text-xs text-white/40 mb-1">Homepage Position <span class="text-white/20">(pin to bento slot)</span></label>
                <select name="position"
                  class="w-full bg-[#0F0F0F] border border-white/10 rounded-sm px-3 py-2 text-sm text-white focus:outline-none focus:border-white/30">
                  <option value="" <%= !item.position?'selected':'' %>>— None —</option>
                  <option value="featured" <%= item.position==='featured'?'selected':'' %>>Featured (large left)</option>
                  <option value="side-1" <%= item.position==='side-1'?'selected':'' %>>Side 1 (top-middle, row 1)</option>
                  <option value="side-2" <%= item.position==='side-2'?'selected':'' %>>Side 2 (top-middle, row 2)</option>
                  <option value="side-3" <%= item.position==='side-3'?'selected':'' %>>Side 3 (top-right, row 1)</option>
                  <option value="side-4" <%= item.position==='side-4'?'selected':'' %>>Side 4 (top-right, row 2)</option>
                </select>
              </div>
              <button type="submit"
                class="bg-white/10 text-white px-4 py-2 rounded-sm text-xs font-medium hover:bg-white/20 transition-colors">
                Save Changes
              </button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

  </div>
  <script>
    function toggleEdit(id) {
      var el = document.getElementById('edit-' + id);
      el.classList.toggle('hidden');
    }

    async function handleUpload() {
      const brand = document.getElementById('brand').value.trim();
      const type = document.getElementById('type').value;
      const brief = document.getElementById('brief').value.trim();
      const position = document.getElementById('position').value;
      const file = document.getElementById('asset').files[0];
      const msgEl = document.getElementById('upload-message');
      const progress = document.getElementById('upload-progress');

      if (!brand || !type || !brief || !file) {
        msgEl.className = 'mb-4 px-4 py-3 rounded-sm text-sm bg-red-900/30 border border-red-500/30 text-red-300';
        msgEl.textContent = 'Please fill in all fields and select a file.';
        return;
      }

      progress.classList.remove('hidden');
      msgEl.className = 'hidden';

      // Step 1: get signature from server
      const sigRes = await fetch('/admin/sign-upload');
      const { timestamp, signature, api_key, cloud_name } = await sigRes.json();

      // Step 2: upload directly to Cloudinary
      const isVideo = /\.(mp4|mov|webm)$/i.test(file.name);
      const formData = new FormData();
      formData.append('file', file);
      formData.append('folder', 'ayrus-creatives');
      formData.append('timestamp', timestamp);
      formData.append('signature', signature);
      formData.append('api_key', api_key);

      const resourceType = isVideo ? 'video' : 'image';
      const uploadRes = await fetch(`https://api.cloudinary.com/v1_1/${cloud_name}/${resourceType}/upload`, {
        method: 'POST',
        body: formData,
      });

      if (!uploadRes.ok) {
        const err = await uploadRes.json();
        progress.classList.add('hidden');
        msgEl.className = 'mb-4 px-4 py-3 rounded-sm text-sm bg-red-900/30 border border-red-500/30 text-red-300';
        msgEl.textContent = 'Upload failed: ' + (err.error?.message || 'Unknown error');
        return;
      }

      const uploaded = await uploadRes.json();

      // Step 3: save metadata on server
      const saveRes = await fetch('/admin/upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ brand, type, brief, position, public_id: uploaded.public_id, resource_type: resourceType }),
      });

      progress.classList.add('hidden');

      if (saveRes.ok) {
        msgEl.className = 'mb-4 px-4 py-3 rounded-sm text-sm bg-green-900/30 border border-green-500/30 text-green-300';
        msgEl.textContent = 'Work item added successfully.';
        document.getElementById('brand').value = '';
        document.getElementById('type').value = '';
        document.getElementById('brief').value = '';
        document.getElementById('asset').value = '';
        setTimeout(() => location.reload(), 1000);
      } else {
        const err = await saveRes.json();
        msgEl.className = 'mb-4 px-4 py-3 rounded-sm text-sm bg-red-900/30 border border-red-500/30 text-red-300';
        msgEl.textContent = 'Metadata save failed: ' + err.error;
      }
    }
  </script>

  <% } %>
</body>
</html>