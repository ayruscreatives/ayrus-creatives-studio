        <span class="hero-h1-line">
          <span style="background:linear-gradient(135deg,#A87DF5,#F472B6);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">Reality,</span>
          &nbsp;Beyond
        </span>
