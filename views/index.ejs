        <span class="marquee-item">AI UGC's</span>
        <span class="marquee-dot">&#10022;</span>
        <span class="marquee-item">ASMR Videos</span>
        <span class="marquee-dot">&#10022;</span>
        <span class="marquee-item">Unboxing Videos</span>
        <span class="marquee-dot">&#10022;</span>
        <span class="marquee-item">Billboards</span>
        <span class="marquee-dot">&#10022;</span>
        <span class="marquee-item">Brand Identity</span>
        <span class="marquee-dot">&#10022;</span>
      </div>
    </div>
  </section>


  <!-- ─── WORK ──────────────────────────────────────────── -->
  <section class="work-section" id="work" aria-label="Selected work">
    <div class="section-header reveal">
      <span class="section-number">01</span>
      <h2 class="section-title">Our Projects</h2>
    </div>

    <div class="work-grid">
      <% if (work && work.length > 0) { %>
        <% work.forEach(function(item, index) { %>
          <article
            class="work-card"
            data-index="<%= index %>"
            onclick="openModal(<%= index %>)"
            style="transition-delay: <%= (index % 3) * 0.1 %>s"
            aria-label="<%= item.brand %> &#8212; <%= item.type %>"
          >
            <% if (item.isVideo) { %>
              <video src="<%= item.file %>" muted loop playsinline preload="metadata"></video>
            <% } else { %>
              <img src="<%= item.file %>" alt="<%= item.brand %>" loading="lazy" />
            <% } %>
            <div class="work-overlay">
              <span class="work-type-tag"><%= item.type %></span>
              <p class="work-brand"><%= item.brand %></p>
              <p class="work-brief"><%= item.brief %></p>
            </div>
          </article>
        <% }); %>
      <% } else { %>
        <div class="work-empty">
          <span>&#10022;</span>
          <p>Projects coming soon.</p>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ─── SERVICES ──────────────────────────────────────── -->
  <section class="services-section" id="services" aria-label="Services">
    <div class="section-header reveal">
      <span class="section-number">02</span>
      <h2 class="section-title">What We Create</h2>
    </div>

    <div class="services-bento">

      <article class="service-card">
        <span class="service-card-num">01</span>
        <h3 class="service-name">AI Product Stills</h3>
        <p class="service-desc">Photorealistic product imagery that stops thumbs in their tracks &#8212; no studio, no limits.</p>
        <div class="service-chips">
          <span class="chip">GTP Image 2</span>
          <span class="chip">Nano Banana Pro</span>
          <span class="chip">Cinema Soul 2.0</span>
        </div>
      </article>

      <article class="service-card">
        <span class="service-card-num">02</span>
        <h3 class="service-name">AI UGC's</h3>
        <p class="service-desc">Authentic-feeling user generated content at scale, powered by AI avatars and creative direction.</p>
        <div class="service-chips">
          <span class="chip">Seedance 2.0</span>
          <span class="chip">Kling 3.0</span>
          <span class="chip">Cinema Studio 3.0</span>
        </div>
      </article>

      <article class="service-card">
        <span class="service-card-num">03</span>
        <h3 class="service-name">ASMR Videos</h3>
