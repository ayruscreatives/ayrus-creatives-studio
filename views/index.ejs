        <h3 class="service-name">Brand Identity</h3>
        <p class="service-desc">Logos, visual systems, and brand language crafted at the intersection of AI and strategy.</p>
        <div class="service-chips">
          <span class="chip">GTP Image 2</span>
          <span class="chip">Nano Banana Pro</span>
          <span class="chip">Cinema Soul 2.0</span>
        </div>
      </article>

    </div>
  </section>

  <!-- ─── PACKAGES ──────────────────────────────────────── -->
  <section class="packages-section" id="packages" aria-label="Packages">
    <div class="section-header reveal">
      <span class="section-number">03</span>
      <h2 class="section-title">Packages</h2>
